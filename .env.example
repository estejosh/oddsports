MODEL_STRONG=claude-sonnet-5            # Analyst/Sharp breakdowns + weekly recap

# --- Token budget (USD/day hard ceiling; pipeline degrades gracefully at 100%) ---
DAILY_TOKEN_BUDGET_USD=10
BUDGET_ALERT_THRESHOLD=0.8

# --- Odds/stats data ---
ODDS_API_KEY=                  # e.g. the-odds-api.com or Betchu feed
