# --- Telegram ---
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_WEBHOOK_URL=          # public HTTPS endpoint for webhook mode
TELEGRAM_FREE_CHANNEL_ID=      # public broadcast channel
TELEGRAM_STARTER_CHANNEL_ID=
TELEGRAM_ANALYST_CHANNEL_ID=
TELEGRAM_SHARP_CHANNEL_ID=

# --- Beehiiv (tier source of truth) ---
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# --- BTCPC inference (prose generation only — all math is deterministic code) ---
# OpenAI-compatible gateway: local btcpc-node or https://btcpc.net
BTCPC_API_BASE=http://localhost:4242
BTCPC_API_KEY=                          # account api key (or account name, local dev only)
MODEL_CHEAP=gemma4:latest               # Free/Starter prose
MODEL_STRONG=gemma4:26b                 # Analyst/Sharp breakdowns + weekly recap

# --- Token budget (USD/day hard ceiling; pipeline degrades gracefully at 100%) ---
DAILY_TOKEN_BUDGET_USD=10
BUDGET_ALERT_THRESHOLD=0.8
MAX_PICKS_PER_DAY=10           # prose latency/cost driver: calls = picks x tier depths

# --- Odds/stats data ---
ODDS_API_KEY=                  # e.g. the-odds-api.com or Betchu feed
ODDS_API_BASE=https://api.the-odds-api.com/v4

# --- Link tracking ---
BETCHU_REFERRAL_BASE=https://betchu.example/r/oddsports
SHORTLINK_BASE=                # tracked short-link service base URL
SHORTLINK_API_KEY=

# --- Storage ---
DATABASE_PATH=./data/oddsports.sqlite
